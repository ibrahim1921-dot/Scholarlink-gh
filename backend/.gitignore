.idea/
*.iml
.vscode/
*.project
*.classpath
.settings/

# ── OS files ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Maven wrapper cache ────────────────────────────────────────────────
.mvn/wrapper/maven-wrapper.jar

# ── Document uploads (runtime storage — not part of the codebase) ──────
uploads/

# ── Firebase service account key (never commit) ────────────────────────
firebase-service-account*.json
serviceAccountKey*.json

# Project summary
docs/
*.md