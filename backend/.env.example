# ══════════════════════════════════════════════════════════════════════
#  ScholarLink GH — Environment Variables Template
#
#  SETUP:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in every value marked with <...>
#    3. Never commit .env — it is gitignored
#
#  HOW IT WORKS:
#    spring-dotenv loads .env at startup. Every variable here becomes
#    available in application.properties as ${VAR_NAME} and in Java
#    beans via @Value("${var.name}").
# ══════════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/scholarlinkghdb
DB_USERNAME=postgres
DB_PASSWORD=<your_postgresql_password>

# ── JWT ────────────────────────────────────────────────────────────────
# Generate with PowerShell:
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
JWT_SECRET=<64_char_hex_string>
JWT_ACCESS_TOKEN_EXPIRY_MS=1800000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# ── Mail (Gmail SMTP) ──────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<yourapp@gmail.com>
# Gmail App Password (not your main password):
# https://myaccount.google.com/apppasswords
MAIL_PASSWORD=<gmail_app_password>

# ── Admin Bootstrap ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@scholarlink.gh
ADMIN_PASSWORD=<strong_admin_password>
ADMIN_USERNAME=ScholarLink Admin

# ── Security ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
INACTIVITY_TIMEOUT_MINUTES=30
TRUSTED_PROXY_IPS=

# ── Auth Policy ────────────────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
RESET_TOKEN_EXPIRY_MINUTES=15

# ── OTP ────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_EMAIL_SUBJECT=ScholarLink GH Verification Code

# ── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_REGISTER_CAPACITY=5
RATE_LIMIT_REGISTER_REFILL_MINUTES=60
RATE_LIMIT_LOGIN_CAPACITY=10
RATE_LIMIT_LOGIN_REFILL_MINUTES=15
RATE_LIMIT_OTP_CAPACITY=5
RATE_LIMIT_OTP_REFILL_MINUTES=30
RATE_LIMIT_FORGOT_CAPACITY=5
RATE_LIMIT_FORGOT_REFILL_MINUTES=60
RATE_LIMIT_REFRESH_CAPACITY=30
RATE_LIMIT_REFRESH_REFILL_MINUTES=1
RATE_LIMIT_GENERAL_CAPACITY=60
RATE_LIMIT_GENERAL_REFILL_MINUTES=1

# ── Google Gemini AI ───────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1/models
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.7
GEMINI_CONNECT_TIMEOUT_SECONDS=30
GEMINI_READ_TIMEOUT_SECONDS=60
GEMINI_WRITE_TIMEOUT_SECONDS=30
GEMINI_MATCH_CACHE_HOURS=24
GEMINI_MAX_SCHOLARSHIPS_IN_PROMPT=50

# ── Firebase FCM (Push Notifications) ─────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate key
# Leave blank to disable push notifications.
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=
FIREBASE_PROJECT_ID=

# ── Document Upload ────────────────────────────────────────────────────
DOCUMENT_UPLOAD_DIR=uploads
DOCUMENT_MAX_FILE_SIZE_MB=10
DOCUMENT_DISCLAIMER_VALIDITY_DAYS=90

# ── Server ─────────────────────────────────────────────────────────────
SERVER_PORT=8081
